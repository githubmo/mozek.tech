---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";

const services = [
  {
    num: "01",
    title: "Consulting",
    desc: "End-to-end data strategy and hands-on engineering to accelerate your cloud and data initiatives — from greenfield builds to modernising legacy pipelines.",
    tags: ["AWS", "Azure", "GCP", "Terraform"],
    included: ["Data strategy & roadmap", "Hands-on platform engineering", "Team augmentation", "Delivery leadership"],
  },
  {
    num: "02",
    title: "Training",
    desc: "Expert-led programmes that upskill your engineering teams in modern cloud, data and AI technologies — tailored to your stack and delivered by practitioners.",
    link: { label: "See programmes", href: "/training" },
    included: ["Cohort-based programmes", "Hands-on labs", "Tailored curricula", "On-site or remote"],
  },
  {
    num: "03",
    title: "Architecture Review",
    desc: "An independent assessment of your existing systems to close gaps, reduce cost and improve resilience — with a prioritised, actionable roadmap you own.",
    tags: ["Well-Architected", "FinOps", "Observability"],
    included: ["System & cost audit", "Resilience & DR review", "Security posture", "Prioritised roadmap"],
  },
  {
    num: "04",
    title: "Cloud Native Solutions",
    desc: "Bespoke cloud-native development — from IoT ingestion to real-time analytics and ML-powered products, built to scale and operate reliably.",
    tags: ["Kafka", "Trino", "dbt", "Kubernetes"],
    included: ["Real-time data pipelines", "IoT & event ingestion", "ML-powered products", "Cloud-native applications"],
  },
];

const models = [
  { title: "Project", desc: "A scoped deliverable with a fixed outcome, timeline and price." },
  { title: "Embedded", desc: "Senior engineers working inside your team for a defined period." },
  { title: "Advisory", desc: "Ongoing, lightweight access to our team for direction and review." },
];
---

<Layout title="Services — Mozek Technologies">
  <!-- ══════════ HERO ══════════ -->
  <section class="relative overflow-hidden px-6 pb-14 pt-16 lg:pt-24">
    <div
      class="bg-dotgrid pointer-events-none absolute inset-0"
      style="-webkit-mask-image:radial-gradient(ellipse 75% 70% at 25% 20%,#000 0%,transparent 75%);mask-image:radial-gradient(ellipse 75% 70% at 25% 20%,#000 0%,transparent 75%);"
    >
    </div>
    <div class="relative mx-auto max-w-7xl">
      <span class="animate-on-load font-mono text-[13px] uppercase tracking-[0.14em] text-primary">// services</span>
      <h1 class="animate-on-load-d1 mt-5 max-w-3xl font-heading text-4xl font-bold leading-[1.03] tracking-tight text-ink-50 lg:text-7xl">
        Four ways we plug in.
      </h1>
      <p class="animate-on-load-d2 mt-6 max-w-2xl text-lg leading-relaxed text-ink-400">
        From a one-off architecture review to standing up a production platform
        end to end — we scope each engagement around the outcome you need.
      </p>
    </div>
  </section>

  <!-- ══════════ SERVICE BLOCKS ══════════ -->
  <section class="mx-auto flex max-w-7xl flex-col gap-[18px] px-6 pb-20 lg:pb-28">
    {
      services.map((s) => (
        <div class="rounded-[1.1rem] border border-ink-700/60 bg-base-200 p-7 lg:p-11" data-animate>
          <div class="flex items-baseline gap-4">
            <span class="font-mono text-[15px] text-primary">{s.num}</span>
            <h2 class="font-heading text-2xl font-bold tracking-tight text-ink-50 lg:text-3xl">{s.title}</h2>
          </div>
          <div class="mt-6 flex flex-wrap gap-x-14 gap-y-7">
            <div class="min-w-[280px] flex-[1.3_1_360px]">
              <p class="leading-relaxed text-ink-400">{s.desc}</p>
              {s.tags && (
                <div class="mt-5 flex flex-wrap gap-2">
                  {s.tags.map((t) => (
                    <span class="rounded-full border border-ink-700/60 px-3 py-1.5 font-mono text-xs text-ink-300">{t}</span>
                  ))}
                </div>
              )}
              {s.link && (
                <a href={s.link.href} class="group mt-4 inline-flex items-center gap-2 font-semibold text-primary">
                  {s.link.label} <span class="font-mono transition-transform group-hover:translate-x-0.5">&rarr;</span>
                </a>
              )}
            </div>
            <div class="min-w-[240px] flex-1">
              <div class="mb-3.5 font-mono text-xs uppercase tracking-[0.12em] text-ink-500">Included</div>
              <ul class="flex flex-col gap-2.5">
                {s.included.map((b) => (
                  <li class="flex gap-2.5 text-[14.5px] text-ink-200">
                    <span class="font-mono text-primary">+</span>{b}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))
    }
  </section>

  <!-- ══════════ ENGAGEMENT MODELS ══════════ -->
  <section class="border-y border-ink-700/60 bg-base-200">
    <div class="mx-auto max-w-7xl px-6 py-20 lg:py-24">
      <div class="max-w-xl" data-animate>
        <span class="font-mono text-[13px] uppercase tracking-[0.14em] text-primary">// engagement models</span>
        <h2 class="mt-4 font-heading text-2xl font-bold tracking-tight text-ink-50 lg:text-4xl">However you want to work with us.</h2>
      </div>
      <div class="mt-9 grid gap-[18px] sm:grid-cols-3">
        {
          models.map((m, i) => (
            <div class="rounded-2xl border border-ink-700/60 bg-base-100 p-7" data-animate data-delay={String(i + 1)}>
              <h3 class="font-heading text-xl font-semibold text-ink-50">{m.title}</h3>
              <p class="mt-3 text-[14.5px] leading-relaxed text-ink-400">{m.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTA title="Not sure which fits? Let's scope it together." />
</Layout>
