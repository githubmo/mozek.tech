---
import Layout from "../layouts/Layout.astro";
import WhyMozek from "../components/WhyMozek.astro";
import CTA from "../components/CTA.astro";

const team = [
  {
    name: "Mohammed Abdulrazeg",
    role: "Founder and Director",
    img: "src/images/mo.jpg",
    bio: "Over 15 years of experience leading large-scale data platform initiatives across financial services and healthcare. Specialises in distributed systems design, cloud migration strategy, and building high-performing engineering teams.",
  },
  // {
  //   name: "Team Member 2",
  //   role: "Lead Engineer",
  //   img: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&h=500&fit=crop&crop=face",
  //   bio: "Full-stack data engineer with deep expertise in real-time streaming architectures, Kubernetes-based deployments, and infrastructure-as-code. Previously led platform engineering at a Series B fintech startup.",
  // },
  // {
  //   name: "Team Member 3",
  //   role: "ML Lead",
  //   img: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=400&h=500&fit=crop&crop=face",
  //   bio: "Machine learning engineer and researcher with a background in NLP and computer vision. Passionate about bridging the gap between experimental ML and production-grade systems through robust MLOps practices.",
  // },
];
---

<Layout title="About — Mozek Technologies">
  <!-- ══════════ HERO ══════════ -->
  <section class="relative overflow-hidden pb-20 pt-16 lg:pb-28 lg:pt-24">
    <div
      class="pointer-events-none absolute left-0 top-0 h-[600px] w-[600px] -translate-x-1/3 -translate-y-1/4 rounded-full bg-teal/[0.06] blur-[120px]"
    >
    </div>

    <div class="relative mx-auto max-w-7xl px-6">
      <h1
        class="animate-on-load max-w-3xl font-heading text-4xl font-extrabold leading-tight text-white lg:text-6xl"
      >
        Enterprise-Grade Data&nbsp;&amp;&nbsp;AI Solutions
      </h1>
      <div
        class="animate-on-load-d1 mt-8 max-w-2xl space-y-4 text-lg leading-relaxed text-slate-400"
      >
        <p>
          Mozek Technologies is a trusted partner for organisations seeking to
          harness the full potential of their data. We work alongside your teams
          — not as an outsourced vendor, but as an embedded extension of your
          engineering function — delivering scalable, production-ready
          architectures.
        </p>
        <p>
          With a global delivery capability and deep expertise across every
          major cloud provider, we help enterprises modernise legacy systems,
          build greenfield platforms, and adopt machine learning at scale.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════ TEAM ══════════ -->
  <section class="bg-navy-light py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6">
      <h2
        class="font-heading text-3xl font-bold text-white lg:text-4xl"
        data-animate
      >
        The Mozek Team
      </h2>

      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {
          team.map((m, i) => (
            <div
              class="overflow-hidden rounded-2xl border border-white/[0.06] bg-navy"
              data-animate
              data-delay={String(i + 1)}
            >
              <img
                src={m.img}
                alt={m.name}
                class="h-96 w-full object-cover object-center"
                width="400"
                height="450"
                loading="lazy"
              />
              <div class="p-6">
                <h3 class="font-heading text-lg font-semibold text-white">
                  {m.name}
                </h3>
                <p class="text-sm font-medium text-teal">{m.role}</p>
                <p class="mt-3 text-sm leading-relaxed text-slate-400">
                  {m.bio}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ══════════ WHY MOZEK ══════════ -->
  <WhyMozek />

  <!-- ══════════ CTA ══════════ -->
  <CTA />
</Layout>
