---
import Layout from "../layouts/Layout.astro";
import WhyMozek from "../components/WhyMozek.astro";
import TechLogos from "../components/TechLogos.astro";
import BrandImage from "../components/BrandImage.astro";
---

<Layout title="Contact — Mozek Technologies">
  <!-- ══════════ HERO ══════════ -->
  <section class="relative overflow-hidden pb-20 pt-16 lg:pb-28 lg:pt-24">
    <div
      class="pointer-events-none absolute right-0 top-0 h-[600px] w-[600px] translate-x-1/3 -translate-y-1/4 rounded-full bg-accent/[0.06] blur-[120px]"
    >
    </div>

    <div class="relative mx-auto max-w-7xl px-6">
      <h1
        class="animate-on-load max-w-3xl font-heading text-4xl font-extrabold leading-tight text-ink-50 lg:text-6xl"
      >
        Reliability at Scale, Built for Your Needs
      </h1>
      <p
        class="animate-on-load-d1 mt-6 max-w-2xl text-lg leading-relaxed text-ink-400"
      >
        Mozek Technologies partners with enterprises to design, build, and
        operate modern data and AI platforms. Whether you need strategic
        consulting, hands-on engineering, or training for your team — we are
        ready to help.
      </p>
    </div>
  </section>

  <!-- ══════════ CONTACT DETAILS ══════════ -->
  <section class="bg-base-200 py-20 lg:py-28">
    <div
      class="mx-auto grid max-w-7xl items-center gap-12 px-6 lg:grid-cols-2 lg:gap-20"
    >
      <div data-animate>
        <h2 class="font-heading text-2xl font-bold text-ink-50 lg:text-3xl">
          Get in Touch
        </h2>

        <div class="mt-8 space-y-6">
          <!-- Address -->
          <div>
            <h3
              class="text-xs font-semibold uppercase tracking-widest text-ink-500"
            >
              Address
            </h3>
            <p class="mt-2 leading-relaxed text-ink-300">
              Mozek Technologies Ltd<br />
              The Forum Business Centre<br />
              Swansea, SA9 1HE<br />
              United Kingdom
            </p>
          </div>

          <!-- Email -->
          <div>
            <h3
              class="text-xs font-semibold uppercase tracking-widest text-ink-500"
            >
              Email
            </h3>
            <a
              href="mailto:hello@mozek.tech"
              class="mt-2 inline-block text-accent transition-colors hover:text-secondary"
            >
              hello@mozek.tech
            </a>
          </div>

          <!-- Phone
          <div>
            <h3
              class="text-xs font-semibold uppercase tracking-widest text-ink-500"
            >
              Phone
            </h3>
            <a
              href="tel:+442000000000"
              class="mt-2 inline-block text-accent transition-colors hover:text-secondary"
            >
              +44 20 0000 0000
            </a>
          </div> -->
        </div>
      </div>

      <div data-animate data-delay="2">
        <BrandImage
          src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&h=600&fit=crop"
          alt="Modern office space"
          width={800}
          height={600}
        />
      </div>
    </div>
  </section>

  <!-- ══════════ WHY MOZEK ══════════ -->
  <WhyMozek />

  <!-- ══════════ TECH LOGOS ══════════ -->
  <TechLogos />
</Layout>
