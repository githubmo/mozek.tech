---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";
import { Image } from "astro:assets";
import dealermadeImg from "../images/dealermade.png";

const cards = [
  {
    sector: "FINTECH · PAYMENTS",
    metric: "10×",
    metricLabel: "faster fraud scoring",
    title: "Real-time fraud pipeline",
    desc: "Replaced an hours-behind batch scoring job with a streaming pipeline, scoring transactions in real time without adding operational burden.",
    tags: ["Kafka", "Spark", "Trino"],
  },
  {
    sector: "RETAIL · E-COMMERCE",
    metric: "99.98%",
    metricLabel: "platform uptime",
    title: "Production ML platform",
    desc: "Stood up an MLOps platform from scratch — feature store, training and serving — taking models from notebook to production in weeks, not quarters.",
    tags: ["Kubernetes", "PyTorch", "Airflow"],
  },
  {
    sector: "ENERGY · IOT",
    metric: "−40%",
    metricLabel: "infrastructure cost",
    title: "Zero-downtime cloud migration",
    desc: "Migrated a legacy on-prem warehouse to a cloud-native lakehouse with no downtime, cutting run cost while improving query performance.",
    tags: ["AWS", "dbt", "Terraform"],
  },
];
---

<Layout title="Projects — Mozek Technologies">
  <!-- ══════════ HERO ══════════ -->
  <section class="relative overflow-hidden px-6 pb-12 pt-16 lg:pt-24">
    <div
      class="bg-dotgrid pointer-events-none absolute inset-0"
      style="-webkit-mask-image:radial-gradient(ellipse 75% 70% at 25% 20%,#000 0%,transparent 75%);mask-image:radial-gradient(ellipse 75% 70% at 25% 20%,#000 0%,transparent 75%);"
    >
    </div>
    <div class="relative mx-auto max-w-7xl">
      <span class="animate-on-load font-mono text-[13px] uppercase tracking-[0.14em] text-primary">// selected work</span>
      <h1 class="animate-on-load-d1 mt-5 max-w-3xl font-heading text-4xl font-bold leading-[1.03] tracking-tight text-ink-50 lg:text-7xl">
        Outcomes, not output.
      </h1>
      <p class="animate-on-load-d2 mt-6 max-w-2xl text-lg leading-relaxed text-ink-400">
        Real engagements where we delivered measurable impact. Some specifics are
        withheld under NDA — we're happy to talk through detail on a call.
      </p>
    </div>
  </section>

  <!-- ══════════ FEATURED CASE STUDY — DealerMade ══════════ -->
  <section class="mx-auto max-w-7xl px-6 pb-16 lg:pb-20">
    <div data-animate>
      <span class="font-mono text-[13px] uppercase tracking-[0.14em] text-primary">// client story</span>
      <div class="mt-[18px] overflow-hidden rounded-[1.1rem] border border-ink-700/60 bg-base-200">
        <!-- Client header -->
        <div class="flex items-center gap-4 border-b border-ink-700/60 px-7 py-[22px] lg:px-8">
          <Image src={dealermadeImg} alt="DealerMade logo" class="h-[30px] w-auto" height={30} />
          <div>
            <h2 class="font-heading text-lg font-semibold text-ink-50">DealerMade</h2>
            <p class="mt-0.5 font-mono text-[12.5px] text-ink-500">B2B SaaS &middot; Texas</p>
          </div>
        </div>

        <div class="flex flex-wrap gap-x-12 gap-y-7 p-7 lg:p-10">
          <!-- Narrative -->
          <div class="flex min-w-[300px] flex-[1.3_1_360px] flex-col gap-4 leading-relaxed text-ink-400">
            <p>
              In July of 2024, we reached what felt like the edge of a cliff. All
              our critical services suddenly came to a grinding halt, and none of
              us could accurately identify the source of the problem. We knew the
              problem was related to a particular technology that had been heavily
              adopted into our code base, so we went out looking for help and
              expertise on the technology.
            </p>
            <p>
              We first connected with the team on a Discord forum where we were
              basically screaming for help. The team replied to my inquiries and
              first helped with general questions we had, they proved to be very
              knowledgeable and easy to communicate with, and they quickly gained
              our trust. So, we decided to bring them on as consultants to help us
              through the crisis.
            </p>
            <p>
              Inside of a week, the team was onboarded into our application and was
              down in the trenches with us troubleshooting the problem. Within 2
              weeks we were able to understand the problem, and we found a way to
              mitigate it so our application could get back to work. But then we
              went further, and we worked with the team to review our entire
              application from top to bottom, fleshing out and surfacing other
              vulnerabilities and potential future crisis.
            </p>
          </div>

          <!-- Pull quote -->
          <div class="flex min-w-[280px] flex-1 items-center">
            <blockquote class="relative rounded-2xl border border-primary/25 bg-primary/[0.05] p-[30px]">
              <span class="absolute -top-3.5 left-6 font-heading text-5xl leading-none text-primary/35">&ldquo;</span>
              <p class="leading-relaxed text-ink-100">
                The team helped us rapidly get our application back on track, but
                they also helped us get our hands around the rest of our software
                to make a road map to put us on the right long-term path. As a
                manager I felt the team understood our problems and I was never in
                the dark or out of the loop. As a company we are in a far better
                place today than before and I would absolutely recommend them to
                anyone out there needing high level consultations.
              </p>
              <footer class="mt-5 text-[13.5px]">
                <span class="font-heading font-semibold text-ink-50">James Clark</span>
                <span class="text-ink-500"> — Director of Operations</span>
              </footer>
            </blockquote>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ MORE ENGAGEMENTS ══════════ -->
  <section class="mx-auto max-w-7xl px-6 pb-20 lg:pb-28">
    <div class="mb-9 max-w-2xl" data-animate>
      <span class="font-mono text-[13px] uppercase tracking-[0.14em] text-primary">// more engagements</span>
    </div>
    <div class="grid gap-[18px] sm:grid-cols-2 lg:grid-cols-3">
      {
        cards.map((c, i) => (
          <div
            class="flex flex-col rounded-[1.1rem] border border-ink-700/60 bg-base-200 p-[30px] transition-colors hover:border-primary"
            data-animate
            data-delay={String(i + 1)}
          >
            <div class="font-mono text-xs tracking-wide text-ink-500">{c.sector}</div>
            <div class="mt-[22px] font-heading text-5xl font-bold leading-none tracking-tight text-primary lg:text-[58px]">{c.metric}</div>
            <div class="mt-2 font-mono text-[12.5px] text-ink-500">{c.metricLabel}</div>
            <h3 class="mt-[22px] font-heading text-xl font-semibold text-ink-50">{c.title}</h3>
            <p class="mt-3 flex-1 text-[14.5px] leading-relaxed text-ink-400">{c.desc}</p>
            <div class="mt-5 flex flex-wrap gap-1.5">
              {c.tags.map((t) => (
                <span class="rounded-full border border-ink-700/60 px-2.5 py-1 font-mono text-[11.5px] text-ink-300">{t}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <CTA title="Have a problem like these?" />
</Layout>
