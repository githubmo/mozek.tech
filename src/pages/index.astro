---
import Layout from "../layouts/Layout.astro";
import TechLogos from "../components/TechLogos.astro";
import CTA from "../components/CTA.astro";
---

<Layout title="Mozek Technologies — Data, Cloud & AI Engineering">
  <!-- ══════════ HERO ══════════ -->
  <section class="relative overflow-hidden pb-20 pt-16 lg:pb-32 lg:pt-24">
    <!-- Decorative glow -->
    <div
      class="pointer-events-none absolute right-0 top-0 h-[700px] w-[700px] translate-x-1/3 -translate-y-1/4 rounded-full bg-accent/[0.06] blur-[120px]"
    >
    </div>

    <div class="relative mx-auto max-w-7xl px-6">
      <span
        class="animate-on-load badge badge-outline badge-primary badge-lg"
      >
        Reliability at Scale
      </span>

      <h1
        class="animate-on-load-d1 mt-6 max-w-3xl font-heading text-5xl font-extrabold leading-[1.08] text-ink-50 lg:text-7xl"
      >
        Mozek Technologies
      </h1>

      <p
        class="animate-on-load-d2 mt-6 max-w-2xl text-lg leading-relaxed text-ink-400 lg:text-xl"
      >
        A small team of senior engineers specialising in cloud platforms, data
        engineering, machine learning and AI.
      </p>
    </div>
  </section>

  <!-- ══════════ TECH LOGOS ══════════ -->
  <TechLogos />

  <!-- ══════════ PARTNERS ══════════ -->
  <!-- <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6">
      <h2
        class="text-center text-xs font-semibold uppercase tracking-widest text-ink-500"
        data-animate
      >
        Our Partners
      </h2>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-8">
        {
          ["Partner 1", "Partner 2", "Partner 3", "Partner 4"].map((p, i) => (
            <div
              class="flex h-16 w-44 items-center justify-center rounded-xl border border-ink-700/60 bg-white/[0.02] text-sm text-ink-500"
              data-animate
              data-delay={String(i + 1)}
            >
              {p}
            </div>
          ))
        }
      </div>
    </div>
  </section> -->

  <!-- ══════════ DATA SOLUTIONS ══════════ -->
  <section class="bg-base-200 py-20 lg:py-28">
    <div
      class="mx-auto grid max-w-7xl items-center gap-12 px-6 lg:grid-cols-2 lg:gap-20"
    >
      <div data-animate>
        <h2
          class="max-w-lg font-heading text-3xl font-bold leading-snug text-ink-50 lg:text-4xl"
        >
          Regardless of the size or complexity of your distributted system and
          data requirements, Mozek Technologies will always start with
          understanding your desired business outcomes.
        </h2>
        <p class="mt-6 leading-relaxed text-ink-400">
          We combine deep technical expertise with pragmatic business thinking
          to deliver solutions that are not just architecturally sound but
          genuinely impactful. From greenfield builds to modernising legacy
          pipelines, our approach is always outcome-driven.
        </p>
        <a
          href="/services"
          class="group mt-8 inline-flex items-center gap-1 text-sm font-semibold text-primary transition-colors hover:text-secondary"
        >
          Our Services <span
            class="transition-transform group-hover:translate-x-0.5"
            >&rarr;</span
          >
        </a>
      </div>

      <div data-animate data-delay="2">
        <img
          src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=800&h=600&fit=crop"
          alt="Close-up of a circuit board representing data infrastructure"
          class="w-full rounded-2xl border border-ink-700/60 object-cover"
          width="800"
          height="600"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ══════════ FEATURE LIST ══════════ -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          [
            {
              num: "01",
              title: "Consulting",
              desc: "End-to-end data strategy and hands-on engineering to accelerate your cloud and data initiatives.",
            },
            {
              num: "02",
              title: "Training",
              desc: "Expert-led programmes that upskill your engineering teams in modern cloud, data, and AI technologies.",
            },
            {
              num: "03",
              title: "Architecture Review",
              desc: "Independent assessment of your existing systems to identify gaps, reduce cost, and improve resilience.",
            },
            {
              num: "04",
              title: "Cloud Native Solutions",
              desc: "Bespoke cloud-native development — from IoT ingestion to real-time analytics and ML-powered products.",
            },
          ].map((f, i) => (
            <div
              class="card bg-base-200 border border-ink-700/60"
              data-animate
              data-delay={String(i + 1)}
            >
              <div class="card-body">
                <span class="font-heading text-3xl font-bold text-primary/40">
                  {f.num}
                </span>
                <h3 class="card-title font-heading text-ink-50">
                  {f.title}
                </h3>
                <p class="text-sm leading-relaxed text-ink-400">
                  {f.desc}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ══════════ PROVEN RESULTS ══════════ -->
  <section class="bg-base-200 py-20 lg:py-28">
    <div
      class="mx-auto grid max-w-7xl items-center gap-12 px-6 lg:grid-cols-2 lg:gap-20"
    >
      <div class="order-2 lg:order-1" data-animate data-delay="2">
        <img
          src="https://images.unsplash.com/photo-1504639725590-34d0984388bd?w=800&h=600&fit=crop"
          alt="Engineer working on code representing proven delivery"
          class="w-full rounded-2xl border border-ink-700/60 object-cover"
          width="800"
          height="600"
          loading="lazy"
        />
      </div>

      <div class="order-1 lg:order-2" data-animate>
        <h2 class="font-heading text-3xl font-bold text-ink-50 lg:text-4xl">
          Proven Results
        </h2>
        <p class="mt-6 leading-relaxed text-ink-400">
          We have a track record of delivering tailored data and AI solutions
          that create measurable business impact. Whether it is reducing
          pipeline latency by 10x or standing up a production ML platform from
          scratch, our clients trust us to deliver reliably and on time.
        </p>
        <a
          href="/projects"
          class="group mt-8 inline-flex items-center gap-1 text-sm font-semibold text-primary transition-colors hover:text-secondary"
        >
          Success Stories <span
            class="transition-transform group-hover:translate-x-0.5"
            >&rarr;</span
          >
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════ CTA ══════════ -->
  <CTA />
</Layout>
