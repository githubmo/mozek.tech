---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";
import { Icon } from "astro-icon/components";

// Monochrome icons (inherit currentColor → ink-200). Real catalogue carried over
// from the original site. Add `style={{ color: ic.color }}` to restore brand colours.
const courses: { title: string; icons: { slug: string; name: string }[]; bullets: string[] }[] = [
  {
    title: "Python for Data Engineering",
    icons: [
      { slug: "python", name: "Python" },
      { slug: "pandas", name: "pandas" },
      { slug: "polars", name: "Polars" },
    ],
    bullets: ["Data pipelines with pandas & polars", "Testing, packaging, and CI", "Building production-quality ETL scripts"],
  },
  {
    title: "Cloud Platforms (AWS / Azure / GCP)",
    icons: [
      { slug: "amazonwebservices", name: "AWS" },
      { slug: "microsoftazure", name: "Azure" },
      { slug: "googlecloud", name: "Google Cloud" },
      { slug: "terraform", name: "Terraform" },
    ],
    bullets: ["Infrastructure-as-Code with Terraform", "Networking and security fundamentals", "Managed data & ML services"],
  },
  {
    title: "Containers & Orchestration",
    icons: [
      { slug: "docker", name: "Docker" },
      { slug: "kubernetes", name: "Kubernetes" },
      { slug: "helm", name: "Helm" },
      { slug: "pulumi", name: "Pulumi" },
    ],
    bullets: ["Docker fundamentals & best practices", "Kubernetes deployments & services", "Helm charts and GitOps workflows"],
  },
  {
    title: "Data Pipelines & Streaming",
    icons: [
      { slug: "apachekafka", name: "Apache Kafka" },
      { slug: "apachespark", name: "Apache Spark" },
      { slug: "apacheairflow", name: "Apache Airflow" },
      { slug: "dbt", name: "dbt" },
    ],
    bullets: ["Kafka, Spark, Airflow, dbt", "Real-time vs batch architectures", "Data quality and observability"],
  },
  {
    title: "Machine Learning Fundamentals",
    icons: [
      { slug: "scikitlearn", name: "scikit-learn" },
      { slug: "jupyter", name: "Jupyter" },
      { slug: "numpy", name: "NumPy" },
    ],
    bullets: ["scikit-learn & model evaluation", "Feature engineering strategies", "From notebook to reproducible pipeline"],
  },
  {
    title: "MLOps & Production ML",
    icons: [
      { slug: "mlflow", name: "MLflow" },
      { slug: "githubactions", name: "GitHub Actions" },
      { slug: "grafana", name: "Grafana" },
    ],
    bullets: ["Model serving & inference APIs", "Experiment tracking (MLflow, W&B)", "CI/CD for ML pipelines"],
  },
];

const steps = [
  { num: "01", title: "Discovery call", text: "We discuss your team's current skill levels, tech stack, and learning objectives." },
  { num: "02", title: "Custom curriculum", text: "We design a tailored programme with relevant exercises and real-world scenarios." },
  { num: "03", title: "Delivery & follow-up", text: "Hands-on sessions delivered on-site or remotely, with post-training support and resources." },
];
---

<Layout title="Training — Mozek Technologies">
  <!-- ══════════ HERO ══════════ -->
  <section class="relative overflow-hidden px-6 pb-12 pt-16 lg:pt-24">
    <div
      class="bg-dotgrid pointer-events-none absolute inset-0"
      style="-webkit-mask-image:radial-gradient(ellipse 75% 70% at 25% 20%,#000 0%,transparent 75%);mask-image:radial-gradient(ellipse 75% 70% at 25% 20%,#000 0%,transparent 75%);"
    >
    </div>
    <div class="relative mx-auto max-w-7xl">
      <span class="animate-on-load font-mono text-[13px] uppercase tracking-[0.14em] text-primary">// training</span>
      <h1 class="animate-on-load-d1 mt-5 max-w-3xl font-heading text-4xl font-bold leading-[1.03] tracking-tight text-ink-50 lg:text-7xl">
        Upskill your team on the modern stack.
      </h1>
      <p class="animate-on-load-d2 mt-6 max-w-2xl text-lg leading-relaxed text-ink-400">
        Expert-led, hands-on programmes taught by the same engineers who build
        production systems. Tailored to your stack and delivered on-site or remote.
      </p>
      <div class="animate-on-load-d3 mt-9 inline-flex items-center gap-5 border-l-2 border-primary pl-5">
        <span class="font-heading text-4xl font-bold leading-none tracking-tight text-ink-50 lg:text-5xl">1,000+</span>
        <span class="font-mono text-[13px] tracking-wide text-ink-500">students taught</span>
      </div>
    </div>
  </section>

  <!-- ══════════ CATALOGUE ══════════ -->
  <section class="mx-auto max-w-7xl px-6 pb-20 lg:pb-28">
    <div class="mb-9 max-w-2xl" data-animate>
      <span class="font-mono text-[13px] uppercase tracking-[0.14em] text-primary">// course catalogue</span>
      <h2 class="mt-4 font-heading text-2xl font-bold tracking-tight text-ink-50 lg:text-4xl">Programmes we deliver.</h2>
    </div>
    <div class="grid gap-[18px] sm:grid-cols-2 lg:grid-cols-3">
      {
        courses.map((c, i) => (
          <div
            class="flex flex-col rounded-2xl border border-ink-700/60 bg-base-200 p-7 transition-colors hover:border-primary"
            data-animate
            data-delay={String(Math.min(i + 1, 6))}
          >
            <div class="flex flex-wrap gap-2">
              {c.icons.map((ic) => (
                <span
                  class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-ink-700/60 bg-white/[0.025]"
                  title={ic.name}
                >
                  <Icon name={`simple-icons:${ic.slug}`} aria-label={ic.name} class="h-[18px] w-[18px] text-ink-200" />
                </span>
              ))}
            </div>
            <h3 class="mt-5 font-heading text-xl font-semibold text-ink-50">{c.title}</h3>
            <ul class="mt-4 flex flex-col gap-2.5">
              {c.bullets.map((b) => (
                <li class="flex gap-2.5 text-[14px] leading-relaxed text-ink-300">
                  <span class="font-mono text-primary">+</span>{b}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ══════════ HOW IT WORKS ══════════ -->
  <section class="border-y border-ink-700/60 bg-base-200">
    <div class="mx-auto max-w-7xl px-6 py-20 lg:py-24">
      <div class="max-w-xl" data-animate>
        <span class="font-mono text-[13px] uppercase tracking-[0.14em] text-primary">// how it works</span>
        <h2 class="mt-4 font-heading text-2xl font-bold tracking-tight text-ink-50 lg:text-4xl">Tailored to your team, start to finish.</h2>
      </div>
      <div class="mt-9 grid gap-[18px] sm:grid-cols-3">
        {
          steps.map((s, i) => (
            <div class="rounded-2xl border border-ink-700/60 bg-base-100 p-7" data-animate data-delay={String(i + 1)}>
              <span class="font-mono text-sm text-primary">{s.num}</span>
              <h3 class="mt-4 font-heading text-xl font-semibold text-ink-50">{s.title}</h3>
              <p class="mt-3 text-[14.5px] leading-relaxed text-ink-400">{s.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTA title="Build a programme for your team." subtitle="Tell us your stack and goals — we'll tailor the curriculum." label="Enquire about training" />
</Layout>
