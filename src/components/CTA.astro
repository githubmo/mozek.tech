<section class="relative overflow-hidden bg-base-200 py-20 lg:py-28">
  <!-- Decorative gradient orbs -->
  <div
    class="pointer-events-none absolute -left-40 -top-40 h-[500px] w-[500px] rounded-full bg-accent/[0.07] blur-[100px]"
  ></div>
  <div
    class="pointer-events-none absolute -bottom-32 -right-32 h-[400px] w-[400px] rounded-full bg-accent/[0.05] blur-[100px]"
  ></div>

  <div class="relative mx-auto max-w-3xl px-6 text-center" data-animate>
    <h2 class="font-heading text-3xl font-bold text-ink-50 lg:text-4xl">
      Accelerate your data and AI capabilities
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-ink-400">
      Schedule a 30-minute consultation with our team.
    </p>
    <a href="/contact" class="btn btn-outline btn-primary mt-8">
      Contact &rarr;
    </a>
  </div>
</section>
