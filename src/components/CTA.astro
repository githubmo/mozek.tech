---

<section class="relative overflow-hidden bg-navy-light py-20 lg:py-28">
  <!-- Decorative gradient orbs -->
  <div
    class="pointer-events-none absolute -left-40 -top-40 h-[500px] w-[500px] rounded-full bg-teal/[0.07] blur-[100px]"
  ></div>
  <div
    class="pointer-events-none absolute -bottom-32 -right-32 h-[400px] w-[400px] rounded-full bg-teal/[0.05] blur-[100px]"
  ></div>

  <div class="relative mx-auto max-w-3xl px-6 text-center" data-animate>
    <h2 class="font-heading text-3xl font-bold text-white lg:text-4xl">
      Accelerate your data and AI capabilities
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-slate-400">
      Schedule a 30-minute consultation with our team.
    </p>
    <a
      href="/contact"
      class="mt-8 inline-block rounded-full border border-teal/30 bg-teal/10 px-7 py-3 text-sm font-semibold text-teal transition-all duration-200 hover:bg-teal hover:text-navy"
    >
      Contact &rarr;
    </a>
  </div>
</section>
