---
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const links = [
  { name: "About", href: "/about" },
  { name: "Services", href: "/services" },
  { name: "Projects", href: "/projects" },
  { name: "Training", href: "/training" },
];
---

<header
  class="fixed inset-x-0 top-0 z-[60] border-b border-ink-700/60 bg-base-100/70 backdrop-blur-xl transition-colors"
>
  <div class="mx-auto flex h-[72px] max-w-7xl items-center justify-between px-6">
    <!-- Logo -->
    <a href="/" class="relative z-[60] flex items-center gap-2.5">
      <img src="/mozek-logo.png" alt="Mozek" class="h-7 w-auto" />
      <span class="font-heading text-[1.35rem] font-semibold tracking-tight text-ink-50">mozek</span>
    </a>

    <!-- Desktop -->
    <nav class="hidden items-center gap-8 lg:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "text-sm font-medium transition-colors duration-200",
              path === l.href ? "text-primary" : "text-ink-400 hover:text-ink-50",
            ]}
          >
            {l.name}
          </a>
        ))
      }
      <a
        href="/contact"
        class:list={[
          "inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium transition-colors",
          path === "/contact"
            ? "bg-primary text-primary-content"
            : "border border-ink-600 text-ink-50 hover:border-primary hover:text-primary",
        ]}
      >
        Contact <span class="font-mono">&rarr;</span>
      </a>
    </nav>

    <!-- Hamburger -->
    <button
      id="nav-toggle"
      class="relative z-[60] flex h-10 w-10 items-center justify-center lg:hidden"
      aria-label="Toggle navigation"
      aria-expanded="false"
    >
      <div id="burger" class="flex flex-col gap-[5px]">
        <span class="block h-[2px] w-6 origin-center bg-white transition-all duration-300"></span>
        <span class="block h-[2px] w-6 bg-white transition-all duration-300"></span>
        <span class="block h-[2px] w-4 origin-center bg-white transition-all duration-300"></span>
      </div>
    </button>
  </div>
</header>

<!-- Mobile drawer — sibling of header so fixed positioning resolves to viewport -->
<div
  id="mobile-drawer"
  class="fixed inset-0 z-50 flex translate-x-full flex-col bg-ink-950 px-8 pt-28 transition-transform duration-300 ease-in-out lg:hidden"
>
  {
    links.map((l) => (
      <a
        href={l.href}
        class:list={[
          "block py-3 font-heading text-2xl font-semibold transition-colors",
          path === l.href ? "text-primary" : "text-ink-50 hover:text-primary",
        ]}
      >
        {l.name}
      </a>
    ))
  }
  <a
    href="/contact"
    class:list={[
      "mt-4 block py-3 font-heading text-2xl font-semibold transition-colors",
      path === "/contact" ? "text-primary" : "text-ink-50 hover:text-primary",
    ]}
  >
    Contact &rarr;
  </a>
</div>

<!-- Spacer -->
<div class="h-[72px]" aria-hidden="true"></div>

<script>
  const btn = document.getElementById("nav-toggle");
  const drawer = document.getElementById("mobile-drawer");
  const burger = document.getElementById("burger");

  if (btn && drawer && burger) {
    let open = false;
    const spans = burger.querySelectorAll("span");

    btn.addEventListener("click", () => {
      open = !open;
      btn.setAttribute("aria-expanded", String(open));
      drawer.classList.toggle("translate-x-full", !open);
      drawer.classList.toggle("translate-x-0", open);
      document.body.classList.toggle("overflow-hidden", open);

      if (open) {
        (spans[0] as HTMLElement).style.transform = "translateY(3.5px) rotate(45deg)";
        (spans[1] as HTMLElement).style.opacity = "0";
        (spans[2] as HTMLElement).style.transform = "translateY(-3.5px) rotate(-45deg)";
        (spans[2] as HTMLElement).style.width = "1.5rem";
      } else {
        (spans[0] as HTMLElement).style.transform = "";
        (spans[1] as HTMLElement).style.opacity = "";
        (spans[2] as HTMLElement).style.transform = "";
        (spans[2] as HTMLElement).style.width = "";
      }
    });
  }
</script>
