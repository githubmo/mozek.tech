---
const navLinks = [
  { name: "About", href: "/about" },
  { name: "Services", href: "/services" },
  { name: "Projects", href: "/projects" },
  // { name: "Insights", href: "/insights" },
  { name: "Training", href: "/training" },
  { name: "Contact", href: "/contact" },
];
---

<footer class="border-t border-ink-700/60 bg-base-200">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:py-20">
    <div class="footer sm:footer-horizontal">
      <!-- Brand -->
      <aside>
        <a href="/" class="text-xl font-heading font-bold text-ink-50">mozek</a>
        <p class="max-w-xs text-sm leading-relaxed text-ink-400">
          Senior engineers specialising in cloud platforms, data engineering,
          machine learning and AI. We help organisations turn complex data
          challenges into competitive advantages.
        </p>
      </aside>

      <!-- Navigation -->
      <nav>
        <h6 class="footer-title">Navigation</h6>
        {
          navLinks.map((l) => (
            <a href={l.href} class="link link-hover">
              {l.name}
            </a>
          ))
        }
      </nav>

      <!-- Connect -->
      <nav>
        <h6 class="footer-title">Connect</h6>
        <a href="mailto:hello@mozek.tech" class="link link-hover text-primary">
          hello@mozek.tech
        </a>
      </nav>
    </div>

    <!-- Copyright -->
    <div
      class="mt-14 border-t border-ink-700/60 pt-8 text-center text-xs text-ink-500"
    >
      &copy; 2026 Mozek Technologies Ltd. All rights reserved.
    </div>
  </div>
</footer>
