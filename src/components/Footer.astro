---
const navLinks = [
  { name: "About", href: "/about" },
  { name: "Services", href: "/services" },
  { name: "Projects", href: "/projects" },
  { name: "Training", href: "/training" },
  { name: "Contact", href: "/contact" },
];
---

<footer class="border-t border-ink-700/60 bg-base-100">
  <div class="mx-auto max-w-7xl px-6 pt-16 pb-9 lg:pt-20">
    <div class="flex flex-wrap gap-12">
      <!-- Brand -->
      <div class="min-w-[280px] flex-[2_1_360px]">
        <a href="/" class="mb-4 flex items-center gap-2.5">
          <img src="/mozek-logo.png" alt="Mozek" class="h-7 w-auto" />
          <span class="font-heading text-xl font-semibold tracking-tight text-ink-50">mozek</span>
        </a>
        <p class="max-w-md text-sm leading-relaxed text-ink-400">
          Senior engineers specialising in cloud platforms, data engineering,
          machine learning and AI. We help organisations turn complex data
          challenges into competitive advantages.
        </p>
      </div>

      <!-- Navigation -->
      <div class="min-w-[140px] flex-1">
        <h6 class="mb-4 font-mono text-xs uppercase tracking-[0.14em] text-ink-500">Navigation</h6>
        <div class="flex flex-col gap-3 text-sm">
          {
            navLinks.map((l) => (
              <a href={l.href} class="text-ink-300 transition-colors hover:text-primary">
                {l.name}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Connect -->
      <div class="min-w-[140px] flex-1">
        <h6 class="mb-4 font-mono text-xs uppercase tracking-[0.14em] text-ink-500">Connect</h6>
        <a href="mailto:hello@mozek.tech" class="text-sm text-ink-300 transition-colors hover:text-primary">
          hello@mozek.tech
        </a>
      </div>
    </div>

    <div class="mt-14 border-t border-ink-700/60 pt-6 font-mono text-xs text-ink-500">
      &copy; 2026 Mozek Technologies Ltd. All rights reserved.
    </div>
  </div>
</footer>
