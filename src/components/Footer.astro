---
const navLinks = [
  { name: "About", href: "/about" },
  { name: "Services", href: "/services" },
  { name: "Projects", href: "/projects" },
  // { name: "Insights", href: "/insights" },
  { name: "Training", href: "/training" },
  { name: "Contact", href: "/contact" },
];
---

<footer class="border-t border-white/[0.06] bg-navy-light">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:py-20">
    <div class="grid gap-12 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href="/" class="text-xl font-heading font-bold text-white">mozek</a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-400">
          Senior engineers specialising in cloud platforms, data engineering,
          machine learning and AI. We help organisations turn complex data
          challenges into competitive advantages.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4
          class="text-xs font-semibold uppercase tracking-widest text-slate-500"
        >
          Navigation
        </h4>
        <ul class="mt-4 space-y-3">
          {
            navLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-slate-400 transition-colors hover:text-white"
                >
                  {l.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4
          class="text-xs font-semibold uppercase tracking-widest text-slate-500"
        >
          Connect
        </h4>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <a
              href="mailto:hello@mozek.tech"
              class="text-slate-400 transition-colors hover:text-teal"
            >
              hello@mozek.tech
            </a>
          </li>
          <!-- <li>
            <a href="tel:+442000000000" class="text-slate-400 transition-colors hover:text-teal">
              +44 20 0000 0000
            </a>
          </li> -->
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div
      class="mt-14 border-t border-white/[0.06] pt-8 text-center text-xs text-slate-500"
    >
      &copy; 2026 Mozek Technologies Ltd. All rights reserved.
    </div>
  </div>
</footer>
