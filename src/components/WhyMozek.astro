---
const cards = [
  {
    title: "Trusted by Leading Enterprises",
    text: "We partner with organisations across finance, healthcare, retail, and the public sector to deliver mission-critical data and AI systems.",
  },
  {
    title: "Tailored Solutions & End-to-End Support",
    text: "No cookie-cutter approaches. Every engagement is scoped to your specific challenges, from initial discovery through production deployment and beyond.",
  },
  {
    title: "Dedicated Team of Experts",
    text: "Our engineers bring deep, hands-on experience across the modern data stack — not theoretical knowledge, but battle-tested expertise from real-world systems.",
  },
  {
    title: "Proven Results, Measurable Impact",
    text: "We measure success by business outcomes: faster time-to-insight, reduced infrastructure costs, and ML models that deliver genuine value in production.",
  },
];
---

<section class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <h2 class="font-heading text-3xl font-bold text-white lg:text-4xl" data-animate>
      Why Mozek?
    </h2>
    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {cards.map((c, i) => (
        <div
          class="card bg-base-200 border border-white/[0.06]"
          data-animate
          data-delay={String(i + 1)}
        >
          <div class="card-body">
            <h3 class="card-title font-heading text-white">{c.title}</h3>
            <p class="text-sm leading-relaxed text-stone-400">{c.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
