---
import { Icon } from "astro-icon/components";

const techs: { name: string; icon: string; color: string }[] = [
  { name: "Python", icon: "simple-icons:python", color: "#3776AB" },
  { name: "Scala", icon: "simple-icons:scala", color: "#DC322F" },
  { name: "Rust", icon: "simple-icons:rust", color: "#F5EFE6" },
  { name: "Go", icon: "simple-icons:go", color: "#00ADD8" },
  { name: "AWS", icon: "simple-icons:amazonwebservices", color: "#FF9900" },
  { name: "Azure", icon: "simple-icons:microsoftazure", color: "#0078D4" },
  { name: "GCP", icon: "simple-icons:googlecloud", color: "#4285F4" },
  { name: "Docker", icon: "simple-icons:docker", color: "#2496ED" },
  { name: "Kubernetes", icon: "simple-icons:kubernetes", color: "#326CE5" },
  { name: "Terraform", icon: "simple-icons:terraform", color: "#7B42BC" },
  { name: "PostgreSQL", icon: "simple-icons:postgresql", color: "#4169E1" },
  { name: "Redis", icon: "simple-icons:redis", color: "#FF4438" },
  { name: "Kafka", icon: "simple-icons:apachekafka", color: "#F5EFE6" },
  { name: "Spark", icon: "simple-icons:apachespark", color: "#E25A1C" },
  { name: "Trino", icon: "simple-icons:trino", color: "#DD00A1" },
  { name: "Airflow", icon: "simple-icons:apacheairflow", color: "#017CEE" },
  { name: "dbt", icon: "simple-icons:dbt", color: "#FF694A" },
  { name: "Pandas", icon: "simple-icons:pandas", color: "#F5EFE6" },
  { name: "PyTorch", icon: "simple-icons:pytorch", color: "#EE4C2C" },
  { name: "TensorFlow", icon: "simple-icons:tensorflow", color: "#FF6F00" },
  { name: "OpenAI", icon: "simple-icons:openai", color: "#F5EFE6" },
  { name: "Anthropic", icon: "simple-icons:anthropic", color: "#D97757" },
  { name: "LangChain", icon: "simple-icons:langchain", color: "#F5EFE6" },
  { name: "Prometheus", icon: "simple-icons:prometheus", color: "#E6522C" },
  { name: "Grafana", icon: "simple-icons:grafana", color: "#F46800" },
  { name: "OpenTelemetry", icon: "simple-icons:opentelemetry", color: "#F5EFE6" },
];
---

<section class="border-y border-white/[0.06] bg-base-100 py-8 overflow-hidden">
  <div class="relative">
    <!-- Fade edges -->
    <div
      class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-base-100 to-transparent"
    ></div>
    <div
      class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-base-100 to-transparent"
    ></div>

    <div class="animate-marquee flex w-max items-center gap-10">
      {/* Duplicate set for seamless loop */}
      {[...techs, ...techs].map((t) => (
        <Icon
          name={t.icon}
          title={t.name}
          aria-label={t.name}
          style={{ color: t.color }}
          class="h-10 w-10 shrink-0 opacity-80 transition-opacity hover:opacity-100"
        />
      ))}
    </div>
  </div>
</section>
